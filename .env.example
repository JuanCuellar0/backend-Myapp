# ============================================================================
# BASES DE DATOS
# ============================================================================
# Desarrollo local
# DATABASE_URL=sqlite:///app.db
# Producción (Azure)
DATABASE_URL=postgresql://user:password@server.postgres.database.azure.com:5432/miproyecto

# ============================================================================
# FLASK
# ============================================================================
FLASK_ENV=production
FLASK_APP=app.py
SECRET_KEY=tu-clave-secreta-cambiar-en-produccion

# ============================================================================
# CORS - SEGURIDAD CRÍTICA
# ============================================================================
# Frontend en desarrollo local
# CORS_ORIGINS=http://localhost:19006,http://localhost:8081
# Frontend en producción
CORS_ORIGINS=https://tuapp.com,https://www.tuapp.com

# ============================================================================
# EXPO - DESARROLLO
# ============================================================================
# Durante desarrollo con ngrok:
# CORS_ORIGINS=http://localhost:5000,https://xxxx-xx-xxx-xxx-xx.ngrok.io

# ============================================================================
# SEGURIDAD
# ============================================================================
DEBUG=False
